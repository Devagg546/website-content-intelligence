# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=Content Intelligence Assistant
APP_ENV=development
DEBUG=true

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Database
# =============================================================================
SQLITE_DB_PATH=data/content_intelligence.db

# =============================================================================
# ChromaDB
# =============================================================================
CHROMA_PERSIST_DIR=data/chromadb
CHROMA_COLLECTION_NAME=website_content

# =============================================================================
# Embeddings
# =============================================================================
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# Crawler
# =============================================================================
MAX_CRAWL_PAGES=500
CRAWL_DELAY_MS=1000
BROWSER_HEADLESS=true

# =============================================================================
# LLM Configuration
# =============================================================================
# Phase 1: Ollama (local)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Phase 2: Cloud APIs (uncomment to use)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=your-anthropic-api-key

# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=your-google-api-key

# =============================================================================
# RAG Settings
# =============================================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
